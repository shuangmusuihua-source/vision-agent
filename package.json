{
  "name": "sumi",
  "version": "1.4.0",
  "description": "A task-focused intelligent workspace for collaborative research, editable documents, skill-driven deliverables, and personal knowledge.",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "electron-builder install-app-deps",
    "pack": "electron-builder --dir && npm run verify:packaged-skills",
    "dist": "electron-builder && npm run verify:packaged-skills",
    "release": "electron-builder --publish always && npm run verify:packaged-skills",
    "verify:packaged-skills": "node scripts/verify-packaged-skills.mjs"
  },
