APPLE_API_ISSUER=
APPLE_API_KEY_ID=
APPLE_API_KEY_PATH=

# Option B: Legacy Apple ID auth
APPLE_ID=
APPLE_PASSWORD=
APPLE_TEAM_ID=

# Sentry Crash Reporting
SENTRY_DSN=

# GitHub Token (for publishing releases)
GH_TOKEN=
