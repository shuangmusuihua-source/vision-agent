# Apple Code Signing & Notarization
# Developer ID signing certificate
CSC_LINK=
CSC_KEY_PASSWORD=

# Option A: App Store Connect API Key (recommended)
APPLE_API_ISSUER=
APPLE_API_KEY_ID=
APPLE_API_KEY=

# Option B: Legacy Apple ID auth
APPLE_ID=
APPLE_APP_SPECIFIC_PASSWORD=
APPLE_TEAM_ID=

# Sentry Crash Reporting
SENTRY_DSN=

# GitHub Token (for publishing releases)
GH_TOKEN=
